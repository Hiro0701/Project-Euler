   "source": [
    "def sum_odd_sqaures(n: int) -> int:\n",
    "    odd_list = list(range(1, n+1, 2))\n",
    "\n",
    "    return sum([\n",
    "        i**2 for i in odd_list\n",
    "    ])"
   ],
